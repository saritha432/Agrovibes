    "@react-navigation/native-stack": "^6.11.0",
    "expo": "^51.0.28",
    "expo-av": "~14.0.7",
    "expo-file-system": "~17.0.1",
    "expo-image-picker": "~15.1.0",
    "expo-linear-gradient": "~13.0.2",
    "expo-media-library": "~16.0.5",
    "metro": "0.80.12",
    "metro-config": "0.80.12",
    "metro-core": "0.80.12",
    "nativewind": "^4.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
