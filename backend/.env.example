PORT=5000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agrovibes
NODE_ENV=development
CORS_ORIGIN=http://localhost:19006

# Razorpay (https://dashboard.razorpay.com/app/keys) — optional; omit in dev for mock checkout
# RAZORPAY_KEY_ID=rzp_test_xxxx
# RAZORPAY_KEY_SECRET=xxxx

# OTP/Auth
# Keep this strong in production.
OTP_HASH_SECRET=change-this-to-a-strong-random-secret
# OTP provider: twilio | msg91
OTP_PROVIDER=msg91
# Set to true in production to disable dev OTP fallback.
OTP_STRICT_PROVIDER=false

# MSG91 (India OTP)
# MSG91_AUTH_KEY=xxxxxxxxxxxxxxxx
# MSG91_TEMPLATE_ID=xxxxxxxxxxxxxxxx
# Optional for some MSG91 OTP configurations:
# MSG91_SENDER_ID=AGRVIB
# Optional depending on your MSG91 setup
# MSG91_FLOW_ID=xxxxxxxxxxxxxxxx

# Twilio Verify
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
